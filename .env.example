# Supabase project credentials.
#
# The same env-var names are used across every environment (local dev,
# dev.whos-where.com, demo.whos-where.com, future tenants). Differentiation
# happens at the Vercel-project level — each project gets its own values
# pointing at its own Supabase project. The app code reads these via
# process.env directly and doesn't know which environment it's in.
#
# Get the values for a given project from Supabase dashboard:
#   Project Settings → API → "Publishable and secret API keys".
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable key — safe to expose in the browser (starts with sb_publishable_).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — server-side only, never expose to the browser (starts with sb_secret_).
SUPABASE_SECRET_KEY=

# Per-tenant sign-in allowlist. Comma-separated emails. The /sign-in
# server action will only send a magic link to addresses on this list;
# everything else gets the same "check your email" message but no OTP
# is dispatched. Set this independently on every Vercel project so the
# dev / demo / future tenants each authorize their own foreman.
ALLOWED_EMAILS=

# Optional, dev-only. Comma-separated LAN hostnames so the dev server
# accepts cross-origin requests from a phone on the same WiFi.
# Find your Mac's LAN IP with: ifconfig en0 | awk '/inet / {print $2}'
# Production deploys are same-origin so this isn't read in prod.
# DEV_LAN_ORIGINS=192.168.1.100

# Optional. Pins the request origin used for magic-link callback URLs and
# sign-out redirects. Set this on the Production scope of each Vercel
# project (e.g. https://demo.whos-where.com for the whoswhere-demo project).
# Leave unset for previews and local dev — the publicOrigin() fallback
# infers the origin from x-forwarded-host/host headers, which is the right
# behavior for unique-per-deploy preview URLs and Cloudflare-tunnel local dev.
# APP_ORIGIN=https://demo.whos-where.com
