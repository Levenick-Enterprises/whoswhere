# Supabase project credentials.
# Get these from Project Settings → API → "Publishable and secret API keys".
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable key — safe to expose in the browser (starts with sb_publishable_).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — server-side only, never expose to the browser (starts with sb_secret_).
SUPABASE_SECRET_KEY=
